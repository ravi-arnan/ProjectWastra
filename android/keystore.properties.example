# Release signing config — COPY to `keystore.properties` (git-ignored) and fill in.
# Never commit the real file or the .jks keystore.
#
# Generate a keystore (once; keep the .jks + these passwords safe and backed up —
# losing them means you can never update the app on Play):
#   keytool -genkeypair -v -keystore wastra-release.jks \
#     -alias wastra -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ directory (or use an absolute path).

storeFile=wastra-release.jks
storePassword=CHANGE_ME
keyAlias=wastra
keyPassword=CHANGE_ME
