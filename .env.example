VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile site key (public). When set, auth forms render
# a captcha widget and pass the token to Supabase. Leave empty in
# dev if you don't want captcha. Also enable Captcha in the Supabase
# dashboard → Authentication → Attack Protection and paste the
# Turnstile secret key there.
VITE_TURNSTILE_SITE_KEY=

# --- Capacitor / Android APK build (public, VITE_-prefixed) ---
# Only used inside the native shell. On the web these are ignored (the app is
# same-origin with its API and OAuth callbacks). Defaults to the deployed Vercel
# origin in src/lib/platform.ts, so you usually leave these empty.
# Override only for a staging APK that should hit a different backend.
VITE_API_BASE=
VITE_APP_URL=

# Server-side only (set in Vercel dashboard, NOT prefixed with VITE_).
# GitHub PAT for GitHub Models inference (used by /api/ai-analysis).
# Any valid GitHub token works — no scopes needed for free tier.
GITHUB_TOKEN=ghp_your_github_pat

# Service role key (server-side only, NEVER prefix with VITE_). Required for the
# DB-backed payment flow: lets /api/astrapay-* write the payments table and the
# webhook update status authoritatively. Without it, payments fall back to the
# stateless mock path. Copy from Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# --- AstraPay (SNAP) — server-side only ---
# Leave ALL of these empty to run in MOCK mode: the booking flow renders a
# simulated QRIS and auto-confirms after a short delay (good for demos before
# the hackathon sandbox credentials arrive). Set every value to go live.
ASTRAPAY_BASE_URL=
ASTRAPAY_CLIENT_KEY=
ASTRAPAY_CLIENT_SECRET=
ASTRAPAY_MERCHANT_ID=
# RSA private key (PEM). In Vercel, paste the full key incl. BEGIN/END lines.
ASTRAPAY_PRIVATE_KEY=
# Optional: dedicated secret for verifying inbound webhook signatures. Falls
# back to ASTRAPAY_CLIENT_SECRET when unset.
ASTRAPAY_WEBHOOK_SECRET=
# Optional tuning (mock only): how long before a mock charge auto-pays, and
# how long any QR stays valid. Milliseconds.
ASTRAPAY_MOCK_PAY_DELAY_MS=6000
ASTRAPAY_QR_EXPIRES_MS=300000
