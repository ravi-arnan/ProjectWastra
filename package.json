    "@gsap/react": "^2.1.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@motionone/react": "^10.16.4",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.2.2",
    "gsap": "^3.15.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "motion": "^12.38.0",
    "ogl": "^1.0.11",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
